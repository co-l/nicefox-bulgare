# NiceFox GraphDB
GRAPHDB_URL=https://graphdb.nicefox.net
GRAPHDB_PROJECT=bulgare
GRAPHDB_API_KEY=your_graphdb_api_key

# Authentication (SSO via auth.nicefox.net)
# JWT_SECRET must match the secret used by auth.nicefox.net
JWT_SECRET=your_jwt_secret_here_min_32_chars
AUTH_SERVICE_URL=https://auth.nicefox.net

# Mistral AI
MISTRAL_API_KEY=your_mistral_api_key

# ElevenLabs TTS
# Get your key at: https://elevenlabs.io/
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# Server
PORT=3188
FRONTEND_URL=http://localhost:5180
